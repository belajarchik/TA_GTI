{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build OpenGL",
            "type": "shell",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",

                "-IC:\\msys64\\mingw64\\include",
                "-LC:\\msys64\\mingw64\\lib",

                "-lglfw3",
                "-lglew32",
                "-lopengl32",
                "-lgdi32"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}